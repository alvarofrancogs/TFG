FROM node:22-alpine
WORKDIR /app

# Copiar package.json primero para cachear npm install
COPY package.json package-lock.json ./
RUN npm ci

# Copiar toda la configuración del workspace (angular.json, tsconfig, etc.)
# El directorio src se sobreescribirá con el volumen en runtime para hot reload
COPY . .

EXPOSE 4200

# Usa polling para que Docker en Windows detecte cambios en archivos
CMD ["npm", "run", "start:docker"]
